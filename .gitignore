# Dependencies
node_modules/
package-lock.json

# Environment variables
.env
.env.local
.env.*.local

# Uploads - ignore all files except .gitkeep
backend-node/uploads/*
!backend-node/uploads/.gitkeep
uploads/*
!uploads/.gitkeep

# ChromaDB data - ignore database files but keep folder structure
chroma/
chroma_data/*
!chroma_data/.gitkeep
*.chromadb
*.sqlite3

# Data folder - ignore PDFs and other documents but keep folder structure
data/*.pdf
data/*.docx
data/*.xlsx
data/*.pptx
data/*.csv

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# OS
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# Build outputs
dist/
build/
*.tsbuildinfo

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
venv/
env/
.venv

# Testing
coverage/
.nyc_output/

# Temporary files
*.tmp
*.temp
.cache/
